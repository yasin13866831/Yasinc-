#include <iostream>

using namespace std;

int main()
{
    int c[5];
    int max;

    cout<<"enter your 5 numbers:"<<endl;

    for (int i=0;i<5; i++)
        cin>>c[i];

    max=c[1];
    for (int i=1;i<5;i++)
        if(c[i]> max)
        max=c[i];

    cout<<"the max number is:"<<max<<endl;
    return 0;
}
